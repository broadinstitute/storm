# Example SAIGE driver config for Storm chr22 smoke test.
# Copy and edit paths; set plink_prefix OR sparse GRM files before Step 1.
#
# Run from repo root:
#   Rscript scripts/saige/run_saige.R --config scripts/saige/example_chr22.config

# repo_root=   # leave blank: inferred as parent of scripts/saige/

pheno_file=scratch/saige_stage/chr22.saige_synthetic_pheno_covar.tsv
pheno_col=pheno_binary
trait_type=binary
sample_id_col=IID
covar_col_list=sex,age,seq_depth_log,PC1,PC2,PC3,PC4,PC5
q_covar_col_list=

chrom=chr22
n_threads=4

output_dir=scratch/saige_runs/chr22_smoke
run_prefix=binary_null

# --- Step 1: relatedness (fill at least one mode) ---
# Smoke test: unrelated identity sparse GRM from notebook (write_unrelated_identity_sparse_grm_for_saige).
# For real runs use PLINK and/or SAIGE createSparseGRM; if you only have sparse GRM, set skip_variance_ratio_estimation=TRUE.
plink_prefix=
use_sparse_grm=TRUE
sparse_grm_file=scratch/saige_stage/chr22.unrelated_identity.sparseGRM.mtx
sparse_grm_sample_id_file=scratch/saige_stage/chr22.unrelated_identity.sparseGRM.mtx.sampleIDs.txt
skip_variance_ratio_estimation=TRUE
inv_normalize=FALSE

# --- Step 2: Storm DS VCFs (indexes default to VCF + .csi) ---
vcf_standard_sv=scratch/saige_stage/chr22.standard_sv.ds.vcf.bgz
vcf_tr_quantitative=scratch/saige_stage/chr22.tr_quantitative.ds.vcf.bgz
vcf_index_standard_sv=
vcf_index_tr_quantitative=

min_maf=0
min_mac=20
# Sparse GRM null fit: SAIGE forces LOCO off in the .rda; driver also sets Step 2 LOCO=FALSE.
# Use loco=TRUE when Step 1 used full GRM / PLINK only (no --useSparseGRMtoFitNULL).
loco=FALSE
is_fast_test=FALSE

# Optional: different GRM paths for Step 2 (defaults to Step 1 sparse paths)
sparse_grm_file_step2=
sparse_grm_sample_id_file_step2=

# skip_step1=FALSE
# skip_step2=FALSE
